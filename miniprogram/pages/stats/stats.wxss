.page {
	min-height: 100vh;
	background: #F1F5F9;
	padding: 20rpx 24rpx 180rpx;
}

/* ==================== 概览指标网格 ==================== */

.st-grid {
	display: flex;
	flex-wrap: wrap;
	gap: 16rpx;
	margin-bottom: 20rpx;
}

.st-mc {
	width: calc(50% - 8rpx);
	background: #FFFFFF;
	border-radius: 16rpx;
	padding: 24rpx;
	box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
	position: relative;
	overflow: hidden;
}

.st-mc-val {
	font-size: 48rpx;
	font-weight: 800;
	color: #0F172A;
	display: block;
	line-height: 1.1;
}

.st-val-red { color: #DC2626; }
.st-val-amber { color: #D97706; }
.st-val-green { color: #059669; }
/* 各类别数值颜色 */
.st-val-c0 { color: #DC2626; }
.st-val-c1 { color: #059669; }
.st-val-c2 { color: #2563EB; }
.st-val-c3 { color: #7C3AED; }
.st-val-c4 { color: #D97706; }
.st-val-c5 { color: #F59E0B; }
.st-val-c6 { color: #0891B2; }
.st-val-c7 { color: #DB2777; }

.st-mc-lbl {
	font-size: 22rpx;
	color: #94A3B8;
	display: block;
	margin-top: 8rpx;
	letter-spacing: 1rpx;
}

.st-mc-bar {
	position: absolute;
	bottom: 0;
	left: 0;
	right: 0;
	height: 6rpx;
}

.st-mc-bar-blue { background: linear-gradient(90deg, #2563EB, #60A5FA); }
.st-mc-bar-red { background: linear-gradient(90deg, #DC2626, #F87171); }
.st-mc-bar-amber { background: linear-gradient(90deg, #D97706, #FBBF24); }
.st-mc-bar-green { background: linear-gradient(90deg, #059669, #34D399); }
/* 各类别底部条颜色 */
.st-mc-bar-c0 { background: linear-gradient(90deg, #DC2626, #F87171); }
.st-mc-bar-c1 { background: linear-gradient(90deg, #059669, #34D399); }
.st-mc-bar-c2 { background: linear-gradient(90deg, #2563EB, #60A5FA); }
.st-mc-bar-c3 { background: linear-gradient(90deg, #7C3AED, #A78BFA); }
.st-mc-bar-c4 { background: linear-gradient(90deg, #D97706, #FBBF24); }
.st-mc-bar-c5 { background: linear-gradient(90deg, #F59E0B, #FCD34D); }
.st-mc-bar-c6 { background: linear-gradient(90deg, #0891B2, #22D3EE); }
.st-mc-bar-c7 { background: linear-gradient(90deg, #DB2777, #F472B6); }

/* ==================== 通用区块 ==================== */

.st-section {
	background: #FFFFFF;
	border-radius: 16rpx;
	padding: 28rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.st-sec-title {
	font-size: 30rpx;
	font-weight: 700;
	color: #0F172A;
	display: block;
	margin-bottom: 24rpx;
}

/* ==================== 7天趋势柱状图 ==================== */

.st-bar-chart {
	display: flex;
	justify-content: space-between;
	align-items: flex-end;
	height: 300rpx;
	padding-top: 40rpx;
}

.st-bar-col {
	display: flex;
	flex-direction: column;
	align-items: center;
	flex: 1;
	height: 100%;
	position: relative;
}

.st-bar-val {
	font-size: 20rpx;
	color: #64748B;
	font-weight: 600;
	margin-bottom: 8rpx;
	min-height: 28rpx;
}

.st-bar-track {
	flex: 1;
	width: 36rpx;
	background: #F1F5F9;
	border-radius: 6rpx 6rpx 0 0;
	display: flex;
	flex-direction: column;
	justify-content: flex-end;
	overflow: hidden;
}

.st-bar-fill-total {
	width: 100%;
	background: linear-gradient(180deg, #3B82F6, #2563EB);
	border-radius: 6rpx 6rpx 0 0;
	min-height: 4rpx;
	position: relative;
	animation: barGrow 0.6s ease-out both;
	transform-origin: bottom;
}

.st-bar-fill-chem {
	width: 100%;
	background: linear-gradient(180deg, #F87171, #DC2626);
	position: absolute;
	bottom: 0;
	left: 0;
	border-radius: 0;
}

.st-bar-label {
	font-size: 20rpx;
	color: #94A3B8;
	margin-top: 10rpx;
}

.st-bar-legend {
	display: flex;
	justify-content: center;
	gap: 32rpx;
	margin-top: 20rpx;
	padding-top: 16rpx;
	border-top: 1rpx solid #F1F5F9;
}

.st-legend-item {
	display: flex;
	align-items: center;
	gap: 8rpx;
}

.st-legend-item text {
	font-size: 22rpx;
	color: #64748B;
}

.st-legend-dot {
	width: 16rpx;
	height: 16rpx;
	border-radius: 4rpx;
}

.st-ld-blue { background: #2563EB; }
.st-ld-red { background: #DC2626; }
/* 各类别图例点颜色 */
.st-ld-c0 { background: #DC2626; }
.st-ld-c1 { background: #059669; }
.st-ld-c2 { background: #2563EB; }
.st-ld-c3 { background: #7C3AED; }
.st-ld-c4 { background: #D97706; }
.st-ld-c5 { background: #F59E0B; }
.st-ld-c6 { background: #0891B2; }
.st-ld-c7 { background: #DB2777; }

/* ==================== 化学仪器占比 ==================== */

.st-ratio-card {
	text-align: center;
	padding: 16rpx 0;
}

.st-ratio-main {
	display: flex;
	align-items: baseline;
	justify-content: center;
	margin-bottom: 24rpx;
}

.st-ratio-num {
	font-size: 96rpx;
	font-weight: 800;
	color: #DC2626;
	line-height: 1;
}

.st-ratio-pct {
	font-size: 36rpx;
	font-weight: 700;
	color: #F87171;
	margin-left: 4rpx;
}

.st-ratio-bar {
	height: 16rpx;
	border-radius: 8rpx;
	overflow: hidden;
	margin: 0 40rpx;
}

.st-ratio-bar-fill {
	height: 100%;
	border-radius: 8rpx;
	transition: width 0.8s ease;
	min-width: 4rpx;
}

/* 各类别占比卡片颜色 */
.st-ratio-card-c0 .st-ratio-num, .st-ratio-card-c0 .st-ratio-pct { color: #DC2626; }
.st-ratio-card-c0 .st-ratio-bar { background: #FEE2E2; }
.st-ratio-card-c0 .st-ratio-bar-fill { background: linear-gradient(90deg, #DC2626, #F87171); }
.st-ratio-card-c1 .st-ratio-num, .st-ratio-card-c1 .st-ratio-pct { color: #059669; }
.st-ratio-card-c1 .st-ratio-bar { background: #D1FAE5; }
.st-ratio-card-c1 .st-ratio-bar-fill { background: linear-gradient(90deg, #059669, #34D399); }
.st-ratio-card-c2 .st-ratio-num, .st-ratio-card-c2 .st-ratio-pct { color: #2563EB; }
.st-ratio-card-c2 .st-ratio-bar { background: #DBEAFE; }
.st-ratio-card-c2 .st-ratio-bar-fill { background: linear-gradient(90deg, #2563EB, #60A5FA); }
.st-ratio-card-c3 .st-ratio-num, .st-ratio-card-c3 .st-ratio-pct { color: #7C3AED; }
.st-ratio-card-c3 .st-ratio-bar { background: #EDE9FE; }
.st-ratio-card-c3 .st-ratio-bar-fill { background: linear-gradient(90deg, #7C3AED, #A78BFA); }
.st-ratio-card-c4 .st-ratio-num, .st-ratio-card-c4 .st-ratio-pct { color: #D97706; }
.st-ratio-card-c4 .st-ratio-bar { background: #FFEDD5; }
.st-ratio-card-c4 .st-ratio-bar-fill { background: linear-gradient(90deg, #D97706, #FBBF24); }
.st-ratio-card-c5 .st-ratio-num, .st-ratio-card-c5 .st-ratio-pct { color: #F59E0B; }
.st-ratio-card-c5 .st-ratio-bar { background: #FEF3C7; }
.st-ratio-card-c5 .st-ratio-bar-fill { background: linear-gradient(90deg, #F59E0B, #FCD34D); }
.st-ratio-card-c6 .st-ratio-num, .st-ratio-card-c6 .st-ratio-pct { color: #0891B2; }
.st-ratio-card-c6 .st-ratio-bar { background: #CFFAFE; }
.st-ratio-card-c6 .st-ratio-bar-fill { background: linear-gradient(90deg, #0891B2, #22D3EE); }
.st-ratio-card-c7 .st-ratio-num, .st-ratio-card-c7 .st-ratio-pct { color: #DB2777; }
.st-ratio-card-c7 .st-ratio-bar { background: #FCE7F3; }
.st-ratio-card-c7 .st-ratio-bar-fill { background: linear-gradient(90deg, #DB2777, #F472B6); }

.st-ratio-meta {
	display: flex;
	justify-content: space-between;
	margin: 16rpx 40rpx 0;
}

.st-ratio-meta-item {
	font-size: 22rpx;
	color: #94A3B8;
}

/* ==================== 水平条形图 ==================== */

.st-h-bars {
	display: flex;
	flex-direction: column;
	gap: 20rpx;
}

.st-hbar-row {
	display: flex;
	align-items: center;
	gap: 12rpx;
}

.st-hbar-rank {
	width: 36rpx;
	height: 36rpx;
	line-height: 36rpx;
	text-align: center;
	font-size: 20rpx;
	font-weight: 700;
	color: #FFFFFF;
	background: #CBD5E1;
	border-radius: 8rpx;
	flex-shrink: 0;
}

.st-hbar-row:first-child .st-hbar-rank { background: #DC2626; }
.st-hbar-row:nth-child(2) .st-hbar-rank { background: #F59E0B; }
.st-hbar-row:nth-child(3) .st-hbar-rank { background: #2563EB; }

.st-hbar-name {
	width: 140rpx;
	font-size: 24rpx;
	color: #0F172A;
	flex-shrink: 0;
	overflow: hidden;
	text-overflow: ellipsis;
	white-space: nowrap;
	font-weight: 500;
}

.st-hbar-name-kw { width: 130rpx; }

.st-hbar-track {
	flex: 1;
	height: 24rpx;
	background: #F1F5F9;
	border-radius: 6rpx;
	overflow: hidden;
}

.st-hbar-fill {
	height: 100%;
	border-radius: 6rpx;
	min-width: 8rpx;
	animation: widthGrow 0.8s ease-out both;
}

.st-hbar-fill-blue { background: linear-gradient(90deg, #2563EB, #60A5FA); }
.st-hbar-fill-red { background: linear-gradient(90deg, #DC2626, #F87171); }
.st-hbar-fill-teal { background: linear-gradient(90deg, #0891B2, #22D3EE); }

.st-hbar-val {
	width: 60rpx;
	font-size: 24rpx;
	font-weight: 700;
	color: #475569;
	text-align: right;
	flex-shrink: 0;
}

/* ==================== 骨架屏补充 ==================== */

.sk-card {
	background: #FFFFFF;
	border-radius: 16rpx;
	padding: 28rpx;
	margin-bottom: 20rpx;
}
