.page {
	min-height: 100vh;
	background: #F1F5F9;
}

/* ==================== 统计头部 ==================== */

.stats-header {
	background: linear-gradient(135deg, #1E3A5F 0%, #1A365D 50%, #1E40AF 100%);
	padding: 32rpx 0 36rpx;
}

.stats-scroll {
	width: 100%;
}

.stats-row {
	display: inline-flex;
	gap: 16rpx;
	padding: 0 24rpx;
	white-space: nowrap;
}

.stat-card {
	min-width: 180rpx;
	flex-shrink: 0;
	background: rgba(255, 255, 255, 0.12);
	border-radius: 14rpx;
	padding: 20rpx 16rpx;
	display: flex;
	flex-direction: column;
	align-items: center;
	backdrop-filter: blur(10rpx);
}

.stat-card-accent { background: rgba(251, 191, 36, 0.18); }
.stat-card-danger { background: rgba(248, 113, 113, 0.18); }
.stat-card-success { background: rgba(52, 211, 153, 0.18); }
.stat-card-info { background: rgba(96, 165, 250, 0.18); }
.stat-card-purple { background: rgba(167, 139, 250, 0.18); }
.stat-card-orange { background: rgba(251, 146, 60, 0.18); }

.stat-val {
	font-size: 44rpx;
	font-weight: 700;
	color: #FFFFFF;
	line-height: 1.2;
}

.stat-lbl {
	font-size: 20rpx;
	color: rgba(255, 255, 255, 0.7);
	margin-top: 6rpx;
	letter-spacing: 1rpx;
}

/* ==================== 筛选栏 ==================== */

.filter-section {
	display: flex;
	align-items: center;
	background: #FFFFFF;
	padding: 16rpx 24rpx;
	border-bottom: 1rpx solid #E2E8F0;
}

.filter-tabs-scroll {
	flex: 1;
	min-width: 0;
}

.filter-tabs {
	display: inline-flex;
	gap: 12rpx;
	white-space: nowrap;
}

.ftab {
	padding: 10rpx 24rpx;
	border-radius: 8rpx;
	font-size: 24rpx;
	color: #64748B;
	background: #F8FAFC;
	font-weight: 500;
	transition: all 0.2s ease;
}

.ftab-on {
	background: #1E40AF;
	color: #FFFFFF;
	box-shadow: 0 2rpx 8rpx rgba(30, 64, 175, 0.3);
}

.ftab:active { transform: scale(0.96); }

.filter-more-btn {
	display: flex;
	flex-direction: column;
	align-items: flex-end;
	padding: 10rpx 0 10rpx 20rpx;
	gap: 5rpx;
	position: relative;
}

.filter-icon-bar {
	width: 28rpx;
	height: 3rpx;
	background: #64748B;
	border-radius: 2rpx;
}

.filter-icon-bar.short { width: 20rpx; }

.filter-more-txt {
	font-size: 18rpx;
	color: #64748B;
	margin-top: 2rpx;
}

.filter-more-btn:active { opacity: 0.6; }

/* ==================== 来源栏 ==================== */

.source-scroll {
	background: #FFFFFF;
	border-bottom: 1rpx solid #E2E8F0;
}

.source-inner {
	display: flex;
	padding: 14rpx 24rpx;
	gap: 12rpx;
	white-space: nowrap;
}

.src-chip {
	display: inline-flex;
	padding: 8rpx 22rpx;
	border-radius: 20rpx;
	font-size: 22rpx;
	color: #64748B;
	background: #F8FAFC;
	border: 1rpx solid #E2E8F0;
	flex-shrink: 0;
	transition: all 0.2s ease;
}

.src-on {
	background: #EFF6FF;
	color: #1E40AF;
	border-color: #BFDBFE;
	font-weight: 500;
}

.src-chip:active { transform: scale(0.96); }

/* ==================== 列表区域 ==================== */

.list-wrap {
	padding: 20rpx 24rpx;
	padding-bottom: 40rpx;
}

/* 骨架屏 */
.sk-card {
	background: #FFFFFF;
	border-radius: 16rpx;
	padding: 28rpx;
	margin-bottom: 20rpx;
}

.sk-row {
	display: flex;
	gap: 12rpx;
}

/* 列表底部提示 */
.list-end {
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 30rpx 0 10rpx;
	gap: 16rpx;
}

.list-end-line {
	width: 80rpx;
	height: 1rpx;
	background: #CBD5E1;
}

.list-end-txt {
	font-size: 22rpx;
	color: #94A3B8;
}
