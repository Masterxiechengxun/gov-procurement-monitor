<view class="page">
	<!-- 顶部统计摘要 -->
	<view class="stats-header anim-fade-in">
		<scroll-view class="stats-scroll" scroll-x="true" enhanced="true" show-scrollbar="{{false}}">
			<view class="stats-row">
				<view class="stat-card">
					<text class="stat-val">{{stats.total}}</text>
					<text class="stat-lbl">采购总量</text>
				</view>
				<view class="stat-card stat-card-accent">
					<text class="stat-val">{{stats.todayNew}}</text>
					<text class="stat-lbl">今日新增</text>
				</view>
			<view wx:for="{{stats.catCounts}}" wx:key="name" class="stat-card {{item.colorClass}}">
				<text class="stat-val">{{item.count}}</text>
				<text class="stat-lbl">{{item.name}}</text>
			</view>
			</view>
		</scroll-view>
	</view>

	<!-- 筛选栏 -->
	<view class="filter-section anim-fade-up anim-d1">
		<scroll-view class="filter-tabs-scroll" scroll-x="true" enhanced="true" show-scrollbar="{{false}}">
			<view class="filter-tabs">
				<view class="ftab {{currentTab === 'all' ? 'ftab-on' : ''}}" bindtap="onTabChange" data-tab="all">
					<text>全部</text>
				</view>
				<view wx:for="{{followedCats}}" wx:key="*this" class="ftab {{currentTab === 'cat:' + item ? 'ftab-on' : ''}}" bindtap="onTabChange" data-tab="cat:{{item}}">
					<text>{{item}}</text>
				</view>
				<view class="ftab {{currentTab === 'today' ? 'ftab-on' : ''}}" bindtap="onTabChange" data-tab="today">
					<text>今日新增</text>
				</view>
			</view>
		</scroll-view>
		<view class="filter-more-btn" bindtap="goToFilter">
			<view class="filter-icon-bar"></view>
			<view class="filter-icon-bar short"></view>
			<view class="filter-icon-bar"></view>
			<text class="filter-more-txt">筛选</text>
		</view>
	</view>

	<!-- 来源快捷栏 -->
	<scroll-view class="source-scroll anim-fade-up anim-d2" scroll-x="true" enhanced="true" show-scrollbar="{{false}}">
		<view class="source-inner">
			<view class="src-chip {{currentSource === '' ? 'src-on' : ''}}" bindtap="onSourceChange" data-source="">
				<text>全部来源</text>
			</view>
			<view
				wx:for="{{sourceList}}"
				wx:key="id"
				class="src-chip {{currentSource === item.id ? 'src-on' : ''}}"
				bindtap="onSourceChange"
				data-source="{{item.id}}"
			>
				<text>{{item.name}}</text>
			</view>
		</view>
	</scroll-view>

	<!-- 列表区域 -->
	<view class="list-wrap">
		<!-- 骨架屏加载态 -->
		<block wx:if="{{showSkeleton}}">
			<view class="sk-card anim-fade-in" wx:for="{{[1,2,3]}}" wx:key="*this">
				<view class="sk-row">
					<view class="skeleton" style="width:100rpx;height:28rpx;"></view>
					<view class="skeleton" style="width:80rpx;height:28rpx;"></view>
				</view>
				<view class="skeleton" style="width:85%;height:34rpx;margin:20rpx 0 12rpx;"></view>
				<view class="skeleton" style="width:65%;height:34rpx;margin-bottom:20rpx;"></view>
				<view class="sk-row">
					<view class="skeleton" style="width:120rpx;height:24rpx;"></view>
					<view class="skeleton" style="width:100rpx;height:24rpx;"></view>
				</view>
			</view>
		</block>

		<!-- 数据列表 -->
		<block wx:if="{{!showSkeleton && list.length > 0}}">
			<procurement-card
				wx:for="{{list}}"
				wx:key="_id"
				item="{{item}}"
				followed-cats="{{followedCats}}"
				bindcardtap="onCardTap"
				data-id="{{item._id}}"
			/>
		</block>

		<!-- 加载更多指示器 -->
		<view wx:if="{{loading && !showSkeleton}}" class="loading-wrap">
			<view class="loading-dot"></view>
			<view class="loading-dot loading-dot-2"></view>
			<view class="loading-dot loading-dot-3"></view>
			<text class="loading-more-txt">加载中</text>
		</view>

		<!-- 空白状态 -->
		<view wx:if="{{!loading && !showSkeleton && list.length === 0}}" class="empty-state">
			<view class="empty-illust">
				<view class="empty-doc">
					<view class="empty-doc-fold"></view>
					<view class="empty-doc-line empty-doc-line-1"></view>
					<view class="empty-doc-line empty-doc-line-2"></view>
					<view class="empty-doc-line empty-doc-line-3"></view>
				</view>
				<view class="empty-mag">
					<view class="empty-mag-handle"></view>
				</view>
			</view>
			<text class="empty-title">暂无采购信息</text>
			<text class="empty-desc">数据将在下次抓取时自动更新\n下拉页面可手动刷新</text>
			<view class="empty-action" bindtap="onPullDownRefresh">
				<text>立即刷新</text>
			</view>
		</view>

		<!-- 没有更多了 -->
		<view wx:if="{{!loading && noMore && list.length > 0}}" class="list-end">
			<view class="list-end-line"></view>
			<text class="list-end-txt">没有更多了</text>
			<view class="list-end-line"></view>
		</view>
	</view>
</view>
