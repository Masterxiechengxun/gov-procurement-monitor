/* ==================== 底部栏容器 ==================== */

.tab-bar {
	display: flex;
	align-items: stretch;
	height: 92rpx;
	background: rgba(255, 255, 255, 0.82);
	backdrop-filter: saturate(180%) blur(24px);
	-webkit-backdrop-filter: saturate(180%) blur(24px);
	box-shadow:
		0 -1rpx 0 rgba(15, 23, 42, 0.03),
		0 -8rpx 32rpx rgba(15, 23, 42, 0.04);
	padding-bottom: constant(safe-area-inset-bottom);
	padding-bottom: env(safe-area-inset-bottom);
	box-sizing: content-box;
	position: relative;
}

/* ==================== 单个 Tab ==================== */

.tab-item {
	flex: 1;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	position: relative;
	min-height: 80rpx;
	transition: transform 0.15s ease;
}

.tab-item:active {
	transform: scale(0.9);
}

/* ==================== 图标 ==================== */
/* 触控区域 ≥ 44px，符合 ui-ux-pro-max touch-target-size 规范 */
.tab-icon-wrap {
	width: 56rpx;
	height: 56rpx;
	display: flex;
	align-items: center;
	justify-content: center;
	border-radius: 12rpx;
	transition: background-color 0.2s ease;
}

.tab-icon {
	width: 48rpx;
	height: 48rpx;
}

/* ==================== 标签文字 ==================== */

.tab-label {
	font-size: 20rpx;
	color: #64748B;
	margin-top: 4rpx;
	font-weight: 400;
	line-height: 1;
	position: relative;
	z-index: 1;
	transition: color 0.2s ease;
}

.tab-active .tab-label {
	color: #2563EB;
	font-weight: 600;
}

