<view class="tab-bar">
	<view
		wx:for="{{list}}"
		wx:key="index"
		class="tab-item {{selected === index ? 'tab-active' : ''}}"
		data-index="{{index}}"
		bindtap="switchTab"
	>
		<view class="tab-icon-wrap">
			<image
				class="tab-icon"
				src="{{selected === index ? item.activeIcon : item.icon}}"
				mode="aspectFit"
			/>
		</view>
		<text class="tab-label">{{item.text}}</text>
	</view>
</view>
