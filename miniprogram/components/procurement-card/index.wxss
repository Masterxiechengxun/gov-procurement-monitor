.pc-card {
	background: #FFFFFF;
	border-radius: 16rpx;
	padding: 28rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04), 0 1rpx 3rpx rgba(15, 23, 42, 0.02);
	position: relative;
	transition: transform 0.15s ease, box-shadow 0.15s ease;
	overflow: hidden;
}

.pc-card:active {
	transform: scale(0.985);
	box-shadow: 0 1rpx 4rpx rgba(15, 23, 42, 0.06);
}

.pc-header {
	display: flex;
	justify-content: space-between;
	align-items: flex-start;
	margin-bottom: 16rpx;
}

.pc-tags {
	display: flex;
	flex-wrap: wrap;
	gap: 8rpx;
	flex: 1;
}

.pc-tag {
	display: inline-flex;
	align-items: center;
	padding: 4rpx 14rpx;
	border-radius: 6rpx;
	font-size: 20rpx;
	font-weight: 500;
	letter-spacing: 0.5rpx;
}

.pc-tag-new {
	background: #FEF3C7;
	color: #92400E;
}

.pc-tag-chem {
	/* 基础样式，具体颜色由 pc-tag-chem-cN 覆盖 */
}
.pc-tag-chem-c0 { background: #FEE2E2; color: #991B1B; }
.pc-tag-chem-c1 { background: #DCFCE7; color: #166534; }
.pc-tag-chem-c2 { background: #DBEAFE; color: #1E40AF; }
.pc-tag-chem-c3 { background: #EDE9FE; color: #5B21B6; }
.pc-tag-chem-c4 { background: #FFEDD5; color: #C2410C; }
.pc-tag-chem-c5 { background: #FEF3C7; color: #B45309; }
.pc-tag-chem-c6 { background: #CCFBF1; color: #0F766E; }
.pc-tag-chem-c7 { background: #FCE7F3; color: #9D174D; }

.pc-tag-src {
	background: #DBEAFE;
	color: #1E40AF;
}

.pc-date {
	font-size: 22rpx;
	color: #94A3B8;
	flex-shrink: 0;
	margin-left: 16rpx;
	padding-top: 2rpx;
}

.pc-title {
	font-size: 30rpx;
	color: #0F172A;
	line-height: 1.55;
	margin-bottom: 16rpx;
	padding-right: 36rpx;
	font-weight: 500;
}

.pc-kw-hl {
	color: #DC2626;
	font-weight: 600;
}

.pc-meta {
	display: flex;
	flex-wrap: wrap;
	gap: 20rpx;
}

.pc-meta-item {
	display: flex;
	align-items: center;
	gap: 8rpx;
}

.pc-meta-dot {
	width: 8rpx;
	height: 8rpx;
	border-radius: 50%;
	flex-shrink: 0;
}

.pc-dot-blue { background: #2563EB; }
.pc-dot-green { background: #059669; }
.pc-dot-amber { background: #D97706; }

.pc-meta-val {
	font-size: 22rpx;
	color: #64748B;
}

.pc-kw-row {
	margin-top: 16rpx;
	padding-top: 14rpx;
	border-top: 1rpx solid #F1F5F9;
}

.pc-kw-label {
	font-size: 20rpx;
	color: #94A3B8;
	margin-bottom: 8rpx;
	display: block;
}

.pc-kw-list {
	display: flex;
	flex-wrap: wrap;
	gap: 8rpx;
}

.pc-kw-chip {
	display: inline-block;
	font-size: 20rpx;
	color: #991B1B;
	background: #FEF2F2;
	padding: 4rpx 12rpx;
	border-radius: 6rpx;
	border: 1rpx solid #FECACA;
}

.pc-arrow {
	position: absolute;
	right: 24rpx;
	top: 50%;
	transform: translateY(-50%);
}

.pc-arrow-icon {
	width: 14rpx;
	height: 14rpx;
	border-right: 3rpx solid #CBD5E1;
	border-bottom: 3rpx solid #CBD5E1;
	transform: rotate(-45deg);
}
